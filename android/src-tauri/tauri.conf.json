{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bhruuu",
  "version": "0.1.0",
  "identifier": "org.bru.app",
  "build": {
    "beforeDevCommand": "cd ../web && yarn dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../web && NEXT_PUBLIC_API_URL=https://dev.helpbuttons.org TAURI_BUILD=1 yarn build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "bhruuu",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
